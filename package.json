{
  "name": "RamTravels",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@cap-js-community/odata-v2-adapter": "^1.15.5",
    "@cap-js/hana": "^1",
    "@cap-js/postgres": "^1",
    "@sap-cloud-sdk/connectivity": "^4.1.2",
    "@sap-cloud-sdk/http-client": "^4.1.2",
    "@sap-cloud-sdk/resilience": "^4.1.2",
    "@sap/cds": "^8",
    "@sap/cds-common-content": "^2.1.0",
    "@sap/xssec": "^4",
    "express": "^4",
    "node-schedule": "^2.1.1",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.8.0",
    "@cap-js/sqlite": "^1",
    "@sap/cds-dk": "^8",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-travels": "cds watch --open travels/webapp/index.html?sap-ui-xx-viewCache=false",
    "undeploy": "cf undeploy RamTravels --delete-services --delete-service-keys --delete-service-brokers",
    "build:gen": "npx cds build --production && node scripts/patch-hdi-node-version.js",
    "build": "rimraf resources mta_archives && npm run build:gen && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "cds": {
    "requires": {
      "employeeDb": {
        "kind": "hana"
      },
      "supplierDb": {
        "kind": "hana"
      },
      "rest_api": {
        "kind": "rest",
        "credentials": {
          "forwardAuthToken": true
        }
      },
      "auth": {
        "[development]": {
          "kind": "basic",
          "users": {
            "employee": {
              "attr": {
                "email": "employee@ramtravels.com",
                "givenName": "Employee",
                "familyName": "User",
                "password": "initial"
              },
              "roles": [
                "Employee"
              ]
            },
            "supplier": {
              "attr": {
                "email": "supplier@ramtravels.com",
                "givenName": "Supplier",
                "familyName": "User",
                "password": "initial"
              },
              "roles": [
                "Supplier"
              ]
            }
          }
        }
      },
      "html5-repo": true,
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        },
        "db": {
          "kind": "hana",
          "multiTenant": true
        }
      }
    },
    "sql": {
      "native_hana_associations": false
    }
  }
}