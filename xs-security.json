{
  "xsappname": "ramtravels",
  "tenant-mode": "dedicated",
  "description": "Security profile for RamTravels - Employee & Supplier Roles",
  "scopes": [
    {
      "name": "uaa.user",
      "description": "UAA"
    },
    {
      "name": "$XSAPPNAME.employee",
      "description": "Access employee container and services"
    },
    {
      "name": "$XSAPPNAME.supplier",
      "description": "Access supplier container and services"
    },
    {
      "name": "$XSAPPNAME.user_read",
      "description": "Read user profiles"
    },
    {
      "name": "$XSAPPNAME.travel_manage",
      "description": "Manage travel information"
    }
  ],
  "role-templates": [
    {
      "name": "Token_Exchange",
      "description": "UAA",
      "scope-references": [
        "uaa.user"
      ]
    },
    {
      "name": "Employee",
      "description": "Employee user role - access employee container",
      "scope-references": [
        "$XSAPPNAME.employee",
        "$XSAPPNAME.user_read",
        "$XSAPPNAME.travel_manage"
      ]
    },
    {
      "name": "Supplier",
      "description": "Supplier user role - access supplier container",
      "scope-references": [
        "$XSAPPNAME.supplier",
        "$XSAPPNAME.user_read",
        "$XSAPPNAME.travel_manage"
      ]
    },
    {
      "name": "Admin",
      "description": "Administrator - full access",
      "scope-references": [
        "$XSAPPNAME.employee",
        "$XSAPPNAME.supplier",
        "$XSAPPNAME.user_read",
        "$XSAPPNAME.travel_manage"
      ]
    }
  ],
  "oauth2-configuration": {
    "token-validity": 900,
    "refresh-token-validity": 1800,
    "redirect-uris": [
     "https://*.applicationstudio.cloud.sap/**",
     "https://*.us10-001.hana.ondemand.com/login/callback",
     "https://*.cfapps.us10-001.hana.ondemand.com/**"
    ],
    "autoapprove": "false"
   },
   "xsenableasyncservice": "true",
   "attributes": [
    {
      "name": "role",
      "description": "User role - Employee or Supplier",
      "valueType": "string"
    }
  ]
}

